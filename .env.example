# Supabase project URL and anon (public) key. Required for Supabase Auth
# (signUp / signInWithPassword / getUser / signOut) via @supabase/ssr and
# @supabase/supabase-js. Safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Service role key. NOT used by the current signUp/signInWithPassword/getUser/
# signOut auth flow. Reserved for future admin operations or RLS-bypassing
# server-side jobs. Never expose this to the browser; keep commented out
# until an actual admin use case needs it.
# SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Future domain-table persistence (statement files, transactions, accounts,
# categories) will go through Supabase Postgres via the Supabase client / SQL,
# not Prisma. No additional connection string is needed here yet.
